{
  "compilerOptions": {
    "lib": ["es2023"],
    "module": "nodenext",
    "target": "ES2024",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "moduleResolution": "nodenext",
    "isolatedModules": true,

    "outDir": "./lib",
    "rootDir": "./src",
  },
  "exclude": ["node_modules", "**/*.test.ts"]
}
